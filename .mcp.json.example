{
  "mcpServers": {
    "q-orca": {
      "command": "q-orca-mcp",
      "type": "stdio",
      "env": {
        "ORCA_API_KEY": "your-api-key-here",
        "ORCA_PROVIDER": "anthropic",
        "ORCA_BASE_URL": "https://api.minimax.io/anthropic",
        "ORCA_MODEL": "MiniMax-M2.7"
      }
    }
  }
}
